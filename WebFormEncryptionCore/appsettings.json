{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RemoteAppUri": "http://localhost:8080/",
  "RemoteAppApiKey": "00000000-0000-0000-0000-000000000001",
  "DatabasePath": "encryption_history.db",
  "ReverseProxy": {
    "Routes": {
      "fallback": {
        "ClusterId": "webform",
        "Order": 9999,
        "Match": {
          "Path": "{**catch-all}"
        },
        "Transforms": [
          { "PathPrefix": "/WebFormEncryptionApp" }
        ]
      }
    },
    "Clusters": {
      "webform": {
        "Destinations": {
          "legacy": {
            "Address": "http://localhost"
          }
        }
      }
    }
  }
}
