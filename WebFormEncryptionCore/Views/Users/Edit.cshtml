@model WebFormEncryptionCore.Models.User
@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit User: @Model.Username</h1>
<a asp-action="Index">&larr; Back to Users</a>

<form method="post" class="mt-3" style="max-width:400px">
    <input type="hidden" name="id" value="@Model.Id" />
    <div class="mb-3 form-check">
        <input type="checkbox" name="isAdmin" value="true" class="form-check-input" id="chkAdmin"
               @(Model.IsAdmin ? "checked" : "") />
        <label class="form-check-label" for="chkAdmin">Admin</label>
    </div>
    <div class="mb-3">
        <label class="form-label">New Password (leave blank to keep)</label>
        <input type="password" name="newPassword" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
