<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="DatabasePath" value="~/App_Data/encryption_history.db" />
    <add key="FilesPath" value="~/App_Data/Files/" />
    <add key="RemoteAppApiKey" value="00000000-0000-0000-0000-000000000001" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.8" />
    <httpRuntime targetFramework="4.8" maxRequestLength="52428800" />
    <authentication mode="Forms">
      <forms loginUrl="Login.aspx" timeout="30" />
    </authentication>
    <authorization>
      <deny users="?" />
    </authorization>
    <sessionState mode="InProc" timeout="30" />
  </system.web>
  <location path="Login.aspx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>
  <location path="SessionApi.ashx">
    <system.web>
      <authorization>
        <allow users="*" />
      </authorization>
    </system.web>
  </location>
</configuration>
